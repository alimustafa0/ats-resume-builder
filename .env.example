# Django core
# Which settings module to load: config.settings.development | config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.development

# Django core
SECRET_KEY=replace-with-output-of-get_random_secret_key
DEBUG=True

# Localization (optional; defaults to UTC)
TIME_ZONE=UTC

# Production only — comma-separated hostnames (ignored in development)
ALLOWED_HOSTS=

# Google AI Studio (Gemini) — free tier, no credit card.
# Get a key at https://aistudio.google.com/apikey  (starts with AIza...)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite